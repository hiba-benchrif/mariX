{% extends 'base.html' %}
{% block content %}
<div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem;">
    <div>
        <h2 style="margin-bottom: 0.25rem;">Notifications</h2>
        <p style="color: var(--text-muted); margin: 0;">Historique de vos alertes et messages.</p>
    </div>
</div>

<div class="card">
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        {% for notif in notifications %}
        <div style="display: flex; gap: 1rem; padding: 1rem; border-radius: 8px; border: 1px solid var(--border); {% if not notif.is_read %}background-color: #F0F9FF; border-color: var(--accent);{% else %}background-color: var(--background);{% endif %}">
            <div style="font-size: 1.5rem; color: {% if notif.type == 'alerte' %}var(--danger){% elif notif.type == 'info' %}var(--primary){% else %}var(--accent){% endif %};">
                {% if notif.type == 'alerte' %}
                <i class="ph-fill ph-warning-circle"></i>
                {% elif notif.type == 'info' %}
                <i class="ph-fill ph-info"></i>
                {% else %}
                <i class="ph-fill ph-bell-ringing"></i>
                {% endif %}
            </div>
            <div style="flex: 1;">
                <p style="margin: 0; font-weight: {% if not notif.is_read %}600{% else %}400{% endif %}; color: var(--text-main);">{{ notif.message }}</p>
                <span style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; display: block;">{{ notif.created_at.strftime('%d/%m/%Y à %H:%M') }}</span>
            </div>
        </div>
        {% else %}
        <div style="text-align: center; padding: 3rem 1rem;">
            <i class="ph ph-bell-slash" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 1rem;"></i>
            <p style="color: var(--text-muted); margin: 0;">Vous n'avez aucune notification.</p>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
